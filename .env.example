# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# GA4 Measurement Protocol (server-side conversions)
# Create at: GA4 Admin → Data Streams → your web stream → Measurement Protocol API secrets
# When unset, the server-side GA4 event is skipped.
GA4_MP_API_SECRET=

# Meta Pixel
# Find at: Events Manager → your Pixel → Settings → Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversions API (server-side, mirrors Pixel events from server)
# Generate at: Events Manager → Settings → Conversions API → Generate access token
# When unset, the server-side Meta event is skipped.
META_CAPI_ACCESS_TOKEN=

# Cloudflare Turnstile (spam protection on /apply form)
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# If unset, the widget is hidden and server-side verification is skipped (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# LINE Messaging API
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
