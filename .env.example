# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Direct Postgres connection (Drizzle ORM + drizzle-kit pull)
# Local Supabase: docker postgres on 54322
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Prod: Vercel-Supabase integration auto-provisions POSTGRES_URL pointing at
# Supavisor's transaction-mode pool (port 6543). lib/db/drizzle.ts falls back
# to POSTGRES_URL when DATABASE_URL is unset, so no manual var-mapping is
# needed on Vercel — just enable the integration.
#
# Manual override (set DATABASE_URL on Vercel if you need to point elsewhere):
# DATABASE_URL=postgresql://postgres.[ref]:[pw]@aws-[region].pooler.supabase.com:6543/postgres

# Staging Supabase DB connection — used to push migrations to staging during PR
# review: `supabase db push --db-url "$STAGING_DB_URL"`. The staging-workflow
# skill and the guard hook (.claude/hooks/guard-prod.sh) rely on this var.
# Staging project ref: ffyrocdufpxubvjlewze. Keep it ONLY in .env.local
# (gitignored) — it embeds the staging DB password.
#
# Grab it yourself — needs `supabase login` + access to the PROD project that
# owns the branch (<prod-ref> is the ref in prod's NEXT_PUBLIC_SUPABASE_URL):
#   supabase branches get staging -o env --project-ref <prod-ref> \
#     | grep '^POSTGRES_URL=' | sed 's/^POSTGRES_URL=/STAGING_DB_URL=/' >> .env.local
# (Prod's own POSTGRES_URL is intentionally NOT retrievable this way.)
# STAGING_DB_URL=postgresql://postgres.ffyrocdufpxubvjlewze:[pw]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?connect_timeout=10

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Cloudflare Turnstile (spam protection on /apply form)
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# If unset, the widget is hidden and server-side verification is skipped (dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# LINE Messaging API
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
